\name{TweedSpot-package}
\alias{TweedSpot}
\alias{TweedSpot-package}
\title{TweedSpot: Self-Adaptive Spatial Tweedie Models for Spatially Variable Gene Detection}
\description{
TweedSpot provides spatially variable gene detection for spatial omics data
using Tweedie generalized additive models with spatial smoothing.
}
\details{
The package currently exposes \code{tweedspot()}, which supports agnostic SVG
detection as well as cell-type-specific SVG detection using either spot-level
cell-type proportions or per-location cell-type labels.
}
\docType{package}
